{
  "name": "ensure-hopjs",
  "version": "0.1.0",
  "description": "Audit and rewrite CDN imports to use hop.js",
  "type": "module",
  "bin": {
    "ensure-hopjs": "./bin/ensure-hopjs.mjs"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
